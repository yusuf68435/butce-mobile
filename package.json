{
  "name": "butce-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" App.tsx",
    "check": "npm run typecheck && npm run lint && npm test -- --silent",
    "eas:login": "eas login",
    "eas:init": "eas init",
    "eas:build:dev": "eas build --profile development --platform ios",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:prod": "eas build --profile production",
    "dev-client:ios": "expo run:ios"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.10",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.34",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
